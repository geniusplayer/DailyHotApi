{
  "compilerOptions": {
    "strict": false,
    "skipLibCheck": true,        // 跳过库文件的类型检查
    "noImplicitAny": false,       // 允许隐式 any
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist"
  },
  "exclude": ["node_modules", "*.test.*", "./dist/**/*"]
}
